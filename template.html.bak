<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {{- /* 在 title 之前设置 document.title，防止导航时标题闪烁 */ -}}
    <script>document.title="{{.PageTitle}}";</script>
    <title>{{.PageTitle}}</title>
    {{if .ServerFavicon}}
    <link rel="icon" href="{{.ServerFavicon}}">{{end}}
    <link rel="stylesheet" href="/static/css/font-awesome.min.css">
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/prism.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js" data-autoloader-path="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/"></script>
    <style>
        body {
            /* 默认主题 (暗色) */
            --bg-primary: #0d1117;
            --bg-secondary: #161b22;
            --bg-tertiary: #21262d;
            --text-primary: #e6edf3;
            --text-secondary: #8b949e;
            --accent: #58a6ff;
            --accent-light: #79b8ff;
            --border: #30363d;
            --dir-icon: #58a6ff;
            --file-icon: #e6edf3;
            --heart: #f85149;
        }

        html.light-theme body,
        html.light-theme-initial body {
            /* GitHub 亮色主题 */
            --bg-primary: #ffffff;
            --bg-secondary: #f6f8fa;
            --bg-tertiary: #eaeef2;
            --text-primary: #24292f;
            --text-secondary: #57606a;
            --accent: #0969da;
            --accent-light: #1f883d;
            --border: #d0d7de;
            --dir-icon: #0969da;
            --file-icon: #24292f;
            --heart: #cf222e;
        }

        /* 代码块行内元素样式 - 暗色主题（GitHub Dark 风格） */
        .readme-content pre[class*="language-"] code .token.comment,
        .readme-content pre[class*="language-"] code .token.prolog,
        .readme-content pre[class*="language-"] code .token.doctype,
        .readme-content pre[class*="language-"] code .token.cdata {
            color: #8b949e !important;
        }

        .readme-content pre[class*="language-"] code .token.punctuation {
            color: #8b949e !important;
        }

        .readme-content pre[class*="language-"] code .token.property,
        .readme-content pre[class*="language-"] code .token.tag,
        .readme-content pre[class*="language-"] code .token.boolean,
        .readme-content pre[class*="language-"] code .token.number,
        .readme-content pre[class*="language-"] code .token.constant,
        .readme-content pre[class*="language-"] code .token.symbol,
        .readme-content pre[class*="language-"] code .token.deleted {
            color: #79c0ff !important;
        }

        .readme-content pre[class*="language-"] code .token.selector,
        .readme-content pre[class*="language-"] code .token.attr-name,
        .readme-content pre[class*="language-"] code .token.string,
        .readme-content pre[class*="language-"] code .token.char,
        .readme-content pre[class*="language-"] code .token.builtin,
        .readme-content pre[class*="language-"] code .token.inserted {
            color: #a5d6ff !important;
        }

        .readme-content pre[class*="language-"] code .token.operator,
        .readme-content pre[class*="language-"] code .token.entity,
        .readme-content pre[class*="language-"] code .token.url,
        .readme-content pre[class*="language-"] code.language-css .token.string {
            color: #79c0ff !important;
        }

        .readme-content pre[class*="language-"] code .token.atrule,
        .readme-content pre[class*="language-"] code .token.attr-value,
        .readme-content pre[class*="language-"] code .token.keyword {
            color: #ff7b72 !important;
        }

        .readme-content pre[class*="language-"] code .token.function,
        .readme-content pre[class*="language-"] code .token.class-name {
            color: #d2a8ff !important;
        }

        .readme-content pre[class*="language-"] code .token.regex,
        .readme-content pre[class*="language-"] code .token.important,
        .readme-content pre[class*="language-"] code .token.variable {
            color: #ffa657 !important;
        }

        /* 亮色主题下的代码高亮颜色（GitHub Light 风格） */
        html.light-theme .readme-content pre[class*="language-"] code .token.comment,
        html.light-theme .readme-content pre[class*="language-"] code .token.prolog,
        html.light-theme .readme-content pre[class*="language-"] code .token.doctype,
        html.light-theme .readme-content pre[class*="language-"] code .token.cdata {
            color: #6e7781 !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.punctuation {
            color: #6e7781 !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.property,
        html.light-theme .readme-content pre[class*="language-"] code .token.tag,
        html.light-theme .readme-content pre[class*="language-"] code .token.boolean,
        html.light-theme .readme-content pre[class*="language-"] code .token.number,
        html.light-theme .readme-content pre[class*="language-"] code .token.constant,
        html.light-theme .readme-content pre[class*="language-"] code .token.symbol,
        html.light-theme .readme-content pre[class*="language-"] code .token.deleted {
            color: #0550ae !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.selector,
        html.light-theme .readme-content pre[class*="language-"] code .token.attr-name,
        html.light-theme .readme-content pre[class*="language-"] code .token.string,
        html.light-theme .readme-content pre[class*="language-"] code .token.char,
        html.light-theme .readme-content pre[class*="language-"] code .token.builtin,
        html.light-theme .readme-content pre[class*="language-"] code .token.inserted {
            color: #0a3069 !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.operator,
        html.light-theme .readme-content pre[class*="language-"] code .token.entity,
        html.light-theme .readme-content pre[class*="language-"] code .token.url,
        html.light-theme .readme-content pre[class*="language-"] code.language-css .token.string {
            color: #0550ae !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.atrule,
        html.light-theme .readme-content pre[class*="language-"] code .token.attr-value,
        html.light-theme .readme-content pre[class*="language-"] code .token.keyword {
            color: #cf222e !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.function,
        html.light-theme .readme-content pre[class*="language-"] code .token.class-name {
            color: #8250df !important;
        }

        html.light-theme .readme-content pre[class*="language-"] code .token.regex,
        html.light-theme .readme-content pre[class*="language-"] code .token.important,
        html.light-theme .readme-content pre[class*="language-"] code .token.variable {
            color: #953800 !important;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.5;
            min-height: 100vh;
            overflow-y: scroll;
            /* 始终显示滚动条，防止布局偏移 */
        }

        /* 主题初始化后启用过渡效果 */
        html.theme-initialized body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .container {
            max-width: 1200px;
            width: 100%;
            margin: 0 auto;
            padding: 20px;
        }

        /* 头部样式 */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 24px;
        }

        .server-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .server-name {
            font-size: 20px;
            font-weight: 600;
        }

        .theme-toggle {
            background: none;
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-primary);
            cursor: pointer;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s ease;
        }

        .theme-toggle:hover {
            background-color: var(--bg-secondary);
        }

        /* 面包屑导航 */
        .breadcrumbs {
            display: block;
            margin: 0 0 20px 0;
            padding: 0;
            text-align: left;
            min-height: 22px;
            /* font-size: 0; 移除，因为需要显示空格 */
        }

        .breadcrumb-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .breadcrumb-link {
            color: var(--text-primary);
            text-decoration: none;
            font-size: 14px;
            padding: 4px 0px;
            transition: color 0.2s ease;
            display: inline-block;
            vertical-align: middle;
            line-height: 1;
            margin: 0;
            font-family: Consolas, "Microsoft YaHei", monospace;
        }

        .breadcrumb-link:hover {
            color: var(--text-primary);
            text-decoration: none;
        }

        .breadcrumb-separator {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .breadcrumb-current {
            color: var(--text-primary);
            font-size: 14px;
            padding: 4px 0px;
            display: inline-block;
            vertical-align: middle;
            line-height: 1;
            margin: 0;
            font-family: Consolas, "Microsoft YaHei", monospace;
        }

        /* 统计信息 */
        .stats {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 13px;
            color: var(--text-secondary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stats-left {
            white-space: nowrap;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        }

        .stats-right {
            white-space: nowrap;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 13px;
        }

        /* 文件列表表格 */
        .file-table {
            width: 100%;
            border-collapse: collapse;
            background-color: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 6px;
            overflow: hidden;
            margin-bottom: 20px;
        }

        .file-table th {
            background-color: var(--bg-tertiary);
            text-align: left;
            padding: 12px 16px;
            font-weight: 700;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-primary);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        /* 表格列宽度 */
        th:first-child {
            width: 50%;
            padding: 10px 16px;
            position: relative;
        }

        th:first-child .th-title {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            vertical-align: middle;
        }

        th:first-child .search-box {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            width: 180px;
        }

        th.file-size {
            width: 10%;
        }

        th.file-modified {
            width: 12%;
            text-align: left;
            padding-right: 0px;
        }

        .file-table th.sortable {
            cursor: pointer;
            user-select: none;
        }

        .file-table th.sortable:hover {
            background-color: var(--bg-tertiary);
        }

        .sort-icon {
            margin-left: 6px;
            opacity: 0.3;
        }

        .file-table th.sortable:hover .sort-icon {
            opacity: 0.6;
        }

        .file-table th.sorted .sort-icon {
            opacity: 1;
        }

        /* 排序标题文字 */
        .th-title {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            vertical-align: middle;
        }

        /* 搜索框样式 */
        .search-box {
            display: inline-block;
            position: relative;
            vertical-align: middle;
            width: 180px;
        }

        .search-input {
            width: 100%;
            padding: 8px 10px 8px 32px;
            font-size: 13px;
            border: 1px solid var(--border);
            border-radius: 6px;
            background-color: var(--bg-primary);
            color: var(--text-primary);
            outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            box-sizing: border-box;
        }

        .search-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.1);
        }

        .search-input::placeholder {
            color: var(--text-secondary);
            font-size: 12px;
        }

        .search-icon {
            position: absolute;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 12px;
            pointer-events: none;
        }

        /* 空目录 */

        .file-table td {
            padding: 12px 16px;
            border-bottom: 1px solid var(--border);
        }

        .file-table tr:last-child td {
            border-bottom: none;
        }

        .file-table tr:hover {
            background-color: var(--bg-tertiary);
        }

        .file-link {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--text-primary);
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .file-link:hover {
            color: var(--accent);
        }

        .file-icon {
            width: 20px;
            text-align: center;
            color: var(--dir-icon);
        }

        .file-icon.file {
            color: var(--file-icon);
        }

        .file-name {
            flex: 1;
        }

        .file-size {
            text-align: left;
            color: var(--text-secondary);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 13px;
        }

        .file-modified {
            text-align: left;
            color: var(--text-secondary);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 13px;
            padding-right: 0;
        }

        /* 表格标题样式 */
        th.file-size {
            text-align: left;
            padding-right: 24px;
        }

        th.file-modified {
            text-align: left;
            padding-right: 0;
        }

        /* 空目录 */
        .empty-directory {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-secondary);
        }

        .empty-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.5;
        }

        /* README 预览 */
        .readme-container {
            margin-top: 40px;
            border-top: 1px solid var(--border);
            padding-top: 24px;
        }

        .readme-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
        }

        .readme-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .readme-content {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 24px;
        }

        .readme-content h1,
        .readme-content h2,
        .readme-content h3,
        .readme-content h4,
        .readme-content h5,
        .readme-content h6 {
            margin-top: 24px;
            margin-bottom: 16px;
            color: var(--text-primary);
        }

        .readme-content h1 {
            border-bottom: 1px solid var(--border);
            padding-bottom: 8px;
        }

        .readme-content p {
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .readme-content code {
            background-color: var(--bg-tertiary);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 13px;
        }

        .readme-content pre {
            background-color: var(--bg-tertiary);
            padding: 16px;
            border-radius: 6px;
            overflow-x: auto;
            margin-bottom: 16px;
            position: relative;
            /* 为复制按钮预留空间 */
            padding-top: 36px;
        }

        .readme-content pre code {
            background: none;
            padding: 0;
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
            font-size: 13px;
            line-height: 1.5;
        }

        /* 代码块复制按钮 */
        .code-copy-btn {
            position: absolute;
            top: 8px;
            right: 8px;
            padding: 4px 8px;
            font-size: 12px;
            background-color: var(--bg-secondary);
            color: var(--text-primary);
            border: 1px solid var(--border);
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s ease;
            z-index: 10;
        }

        .code-copy-btn:hover {
            background-color: var(--bg-tertiary);
            border-color: var(--accent);
        }

        .code-copy-btn.copied {
            background-color: var(--accent-light);
            border-color: var(--accent-light);
            color: #fff;
        }

        .readme-content ul,
        .readme-content ol {
            margin-bottom: 16px;
            padding-left: 24px;
        }

        .readme-content li {
            margin-bottom: 4px;
        }

        .readme-content a {
            color: var(--accent);
            text-decoration: none;
        }

        .readme-content a:hover {
            text-decoration: underline;
        }

        /* 页脚 */
        .footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
            color: var(--text-secondary);
            font-size: 14px;
        }

        .footer-heart {
            color: var(--heart);
            margin: 0 4px;
        }

        /* 响应式设计 */
        @media (max-width: 768px) {
            .container {
                padding: 12px;
            }

            .header {
                flex-direction: column;
                align-items: flex-start;
                gap: 16px;
            }

            .file-table th,
            .file-table td {
                padding: 8px 12px;
            }

            .file-modified {
                display: none;
            }

            .readme-content {
                padding: 16px;
            }
        }
    </style>
    <script>
        // 立即设置主题，防止闪屏
        (function () {
            try {
                // 检查localStorage中的主题偏好
                const savedTheme = localStorage.getItem('theme');
                let shouldBeLight = false;

                if (savedTheme !== null) {
                    // 有保存的主题偏好
                    shouldBeLight = savedTheme === 'light';
                } else {
                    // 没有保存的偏好，检查系统偏好
                    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
                    shouldBeLight = !prefersDark.matches;
                }

                // 立即设置主题类
                if (shouldBeLight) {
                    document.documentElement.classList.add('light-theme-initial');
                }

                // 添加一个类来标记已经设置了初始主题
                document.documentElement.classList.add('theme-initialized');
            } catch (e) {
                // localStorage可能不可用，忽略错误
            }
        })();
    </script>
</head>

<body>
    <div class="container">
        <!-- 头部 -->
        <header class="header">
            <div class="server-info">
                <h1 class="server-name">{{.ServerName}}</h1>
            </div>
            <button class="theme-toggle" id="themeToggle">
                <i class="fas fa-moon" id="themeIcon"></i>
                <span id="themeText">Dark</span>
            </button>
        </header>

        <!-- 面包屑导航 -->
        <nav class="breadcrumbs">
            {{if .Breadcrumbs}}
            {{range $index, $crumb := .Breadcrumbs}}
            {{if $crumb.Last}}
            {{if eq $crumb.Path "."}}
            <span class="breadcrumb-current">/</span>
            {{else}}
            <span class="breadcrumb-current"> {{$crumb.Name}} / </span>
            {{end}}
            {{else}}
            {{if eq $crumb.Path "."}}
            <a href="/" class="breadcrumb-link">/</a>
            {{else}}
            <a href="/{{$crumb.Path}}" class="breadcrumb-link"> {{$crumb.Name}} / </a>
            {{end}}
            {{end}}
            {{end}}
            {{else}}
            <span class="breadcrumb-current">Home</span>
            {{end}}
        </nav>

        <!-- 统计信息 -->
        <div class="stats">
            <span class="stats-left">
                {{.Stats.Directories}} directories, {{.Stats.Files}} files, {{.Stats.TotalSize}} total
            </span>
            {{if .LatestModTime}}
            <span class="stats-right">
                Last Update: {{.LatestModTime}}
            </span>
            {{end}}
        </div>

        <!-- 文件列表 -->
        {{if ne .Path "."}}
        <table class="file-table">
            <thead>
                <tr>
                    <th class="sortable" data-sort="name" data-order="{{.SortOrder}}" data-sort-by="name">
                        <span class="th-title">Name<i class="sort-icon fas fa-sort"></i></span>
                        <div class="search-box">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" class="search-input" id="searchInput" placeholder="Search" />
                        </div>
                    </th>
                    <th class="file-size sortable" data-sort="size" data-order="{{.SortOrder}}" data-sort-by="size">
                        <span class="th-title">Size<i class="sort-icon fas fa-sort"></i></span>
                    </th>
                    <th class="file-modified sortable" data-order="{{.SortOrder}}" data-sort-by="modified">
                        <span class="th-title">Modified<i class="sort-icon fas fa-sort"></i></span>
                    </th>
                </tr>
            </thead>
            <tbody>
                <tr class="parent-dir-row">
                    <td>
                        <a href=".." class="file-link">
                            <i class="fas fa-level-up-alt file-icon"></i>
                            <span class="file-name">..</span>
                        </a>
                    </td>
                    <td class="file-size">-</td>
                    <td class="file-modified">-</td>
                </tr>
                {{if .Items}}
                {{range .Items}}
                <tr>
                    <td>
                        <a href="/{{.Path}}{{if .IsDirectory}}/{{end}}" class="file-link">
                            <i class="{{.IconClass}} file-icon {{if not .IsDirectory}}file{{end}}"></i>
                            <span class="file-name">{{.Name}}{{if .IsDirectory}}/{{end}}</span>
                        </a>
                    </td>
                    <td class="file-size">{{.SizeHuman}}</td>
                    <td class="file-modified">{{.Modified}}</td>
                </tr>
                {{end}}
                {{else}}
                <tr>
                    <td colspan="3" class="empty-directory-cell">
                        <div style="text-align: center; padding: 20px; color: var(--text-secondary);">
                            <i class="fas fa-folder-open"
                                style="font-size: 24px; margin-bottom: 8px; opacity: 0.5;"></i>
                            <p>This directory is empty</p>
                        </div>
                    </td>
                </tr>
                {{end}}
            </tbody>
        </table>
        {{else}}
        {{if .Items}}
        <table class="file-table">
            <thead>
                <tr>
                    <th class="sortable" data-sort="name" data-order="{{.SortOrder}}" data-sort-by="name">
                        <span class="th-title">Name<i class="sort-icon fas fa-sort"></i></span>
                        <div class="search-box">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" class="search-input" id="searchInput" placeholder="Search" />
                        </div>
                    </th>
                    <th class="file-size sortable" data-sort="size" data-order="{{.SortOrder}}" data-sort-by="size">
                        <span class="th-title">Size<i class="sort-icon fas fa-sort"></i></span>
                    </th>
                    <th class="file-modified sortable" data-order="{{.SortOrder}}" data-sort-by="modified">
                        <span class="th-title">Modified<i class="sort-icon fas fa-sort"></i></span>
                    </th>
                </tr>
            </thead>
            <tbody>
                {{range .Items}}
                <tr>
                    <td>
                        <a href="/{{.Path}}{{if .IsDirectory}}/{{end}}" class="file-link">
                            <i class="{{.IconClass}} file-icon {{if not .IsDirectory}}file{{end}}"></i>
                            <span class="file-name">{{.Name}}{{if .IsDirectory}}/{{end}}</span>
                        </a>
                    </td>
                    <td class="file-size">{{.SizeHuman}}</td>
                    <td class="file-modified">{{.Modified}}</td>
                </tr>
                {{end}}
            </tbody>
        </table>
        {{else}}
        <div class="empty-directory">
            <i class="fas fa-folder-open empty-icon"></i>
            <p>This directory is empty</p>
        </div>
        {{end}}
        {{end}}

        <!-- README 预览 -->
        {{if .HasReadme}}
        <div class="readme-container">
            <div class="readme-header">
                <h2 class="readme-title">README.md</h2>
            </div>
            <div class="readme-content">
                {{.ReadmeHTML}}
            </div>
        </div>
        {{end}}

        <!-- 页脚 -->
        <footer class="footer">
            <p>Powered by <i class="fas fa-heart footer-heart"></i> Mirra</p>
        </footer>
    </div>

    <script>
        // 主题切换功能
        document.addEventListener('DOMContentLoaded', function () {
            const themeToggle = document.getElementById('themeToggle');
            const themeIcon = document.getElementById('themeIcon');
            const themeText = document.getElementById('themeText');
            const body = document.body;

            // 从localStorage读取主题偏好
            let isDark = localStorage.getItem('theme') === 'dark';

            // 如果没有保存的偏好，检查当前主题
            if (localStorage.getItem('theme') === null) {
                // 检查是否已经有初始主题设置
                const html = document.documentElement;
                isDark = !html.classList.contains('light-theme-initial') && !html.classList.contains('light-theme');
            }

            // 更新UI
            updateThemeUI();

            // 切换主题
            themeToggle.addEventListener('click', function () {
                isDark = !isDark;
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                updateThemeUI();
            });

            // 监听系统主题变化（仅当没有用户偏好时）
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');
            prefersDark.addEventListener('change', function (e) {
                if (localStorage.getItem('theme') === null) {
                    isDark = e.matches;
                    updateThemeUI();
                }
            });

            function updateThemeUI() {
                const html = document.documentElement;

                if (isDark) {
                    html.classList.remove('light-theme', 'light-theme-initial');
                    themeIcon.className = 'fas fa-sun';
                    themeText.textContent = 'Light';
                } else {
                    html.classList.add('light-theme');
                    html.classList.remove('light-theme-initial');
                    themeIcon.className = 'fas fa-moon';
                    themeText.textContent = 'Dark';
                }
            }
        });

        // 表格排序功能
        document.addEventListener('DOMContentLoaded', function () {
            const titles = document.querySelectorAll('.th-title');
            let currentSort = { by: 'name', order: 'asc' };

            titles.forEach(function (title) {
                title.addEventListener('click', function (e) {
                    e.stopPropagation();
                    const header = this.closest('th');
                    const sortBy = header.dataset.sortBy;
                    const table = this.closest('.file-table');
                    const tbody = table.querySelector('tbody');
                    const rows = Array.from(tbody.querySelectorAll('tr'));

                    // 如果是第一次点击这个列，或者点击的是不同的列
                    if (currentSort.by !== sortBy) {
                        currentSort.by = sortBy;
                        currentSort.order = 'asc';
                    } else {
                        // 点击同一列，切换顺序
                        currentSort.order = currentSort.order === 'asc' ? 'desc' : 'asc';
                    }

                    // 更新所有表头的排序状态
                    const headers = table.querySelectorAll('th.sortable');
                    headers.forEach(function (h) {
                        h.classList.remove('sorted');
                        const icon = h.querySelector('.sort-icon');
                        if (icon) {
                            icon.className = 'sort-icon fas fa-sort';
                        }
                    });

                    // 设置当前表头的状态
                    header.classList.add('sorted');
                    const currentIcon = header.querySelector('.sort-icon');
                    if (currentIcon) {
                        if (currentSort.order === 'asc') {
                            currentIcon.className = 'sort-icon fas fa-sort-up';
                        } else {
                            currentIcon.className = 'sort-icon fas fa-sort-down';
                        }
                    }

                    // 排序行
                    // 过滤掉 ".." 行（有 parent-dir-row 类的行）
                    const dataRows = rows.filter(function (row) {
                        return !row.classList.contains('parent-dir-row');
                    });

                    dataRows.sort(function (a, b) {
                        let aVal, bVal;

                        if (sortBy === 'name') {
                            aVal = a.querySelector('.file-name').textContent.trim();
                            bVal = b.querySelector('.file-name').textContent.trim();
                            // 目录优先
                            const aIsDir = a.querySelector('.fa-folder') !== null;
                            const bIsDir = b.querySelector('.fa-folder') !== null;
                            if (aIsDir && !bIsDir) return currentSort.order === 'asc' ? -1 : 1;
                            if (!aIsDir && bIsDir) return currentSort.order === 'asc' ? 1 : -1;
                        } else if (sortBy === 'size') {
                            const aText = a.querySelector('.file-size').textContent.trim();
                            const bText = b.querySelector('.file-size').textContent.trim();
                            aVal = parseSize(aText);
                            bVal = parseSize(bText);
                        } else if (sortBy === 'modified') {
                            aVal = new Date(a.querySelector('.file-modified').textContent.trim());
                            bVal = new Date(b.querySelector('.file-modified').textContent.trim());
                        }

                        if (aVal < bVal) return currentSort.order === 'asc' ? -1 : 1;
                        if (aVal > bVal) return currentSort.order === 'asc' ? 1 : -1;
                        return 0;
                    });

                    // 重新插入行
                    dataRows.forEach(function (row) {
                        tbody.appendChild(row);
                    });
                });
            });

            // 解析文件大小为字节数
            function parseSize(sizeStr) {
                if (sizeStr === '-') return -1;
                const units = { 'B': 1, 'KiB': 1024, 'MiB': 1024 * 1024, 'GiB': 1024 * 1024 * 1024, 'TiB': 1024 * 1024 * 1024 * 1024 };
                const match = sizeStr.match(/^([\d.]+)\s*([A-Za-z]+)/);
                if (!match) return parseFloat(sizeStr);
                return parseFloat(match[1]) * (units[match[2]] || 1);
            }
        });

        // 搜索筛选功能
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            if (!searchInput) return;

            searchInput.addEventListener('input', function () {
                const filter = this.value.toLowerCase();
                const table = this.closest('.file-table');
                const tbody = table.querySelector('tbody');
                const rows = tbody.querySelectorAll('tr');

                rows.forEach(function (row) {
                    // ".." 行始终显示
                    if (row.classList.contains('parent-dir-row')) {
                        row.style.display = '';
                        return;
                    }

                    const fileName = row.querySelector('.file-name').textContent.trim();
                    if (fileName.toLowerCase().indexOf(filter) > -1) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            });
        });

        // 代码块复制按钮功能
        document.addEventListener('DOMContentLoaded', function () {
            const codeBlocks = document.querySelectorAll('.readme-content pre');

            codeBlocks.forEach(function(pre) {
                // 为代码块添加复制按钮
                const button = document.createElement('button');
                button.className = 'code-copy-btn';
                button.textContent = 'Copy';
                pre.insertBefore(button, pre.firstChild);

                button.addEventListener('click', function() {
                    const code = pre.querySelector('code');
                    if (code) {
                        // 获取代码文本内容（去除末尾换行）
                        const textToCopy = code.textContent.replace(/\n$/, '');
                        navigator.clipboard.writeText(textToCopy).then(function() {
                            button.textContent = 'Copied!';
                            button.classList.add('copied');
                            setTimeout(function() {
                                button.textContent = 'Copy';
                                button.classList.remove('copied');
                            }, 2000);
                        }).catch(function() {
                            button.textContent = 'Failed';
                            setTimeout(function() {
                                button.textContent = 'Copy';
                            }, 2000);
                        });
                    }
                });
            });

            // 手动触发 prism 高亮（确保动态加载的语言也能高亮）
            if (window.Prism) {
                // 使用 setTimeout 确保 autoloader 有时间加载语言
                setTimeout(function() {
                    Prism.highlightAll();
                }, 100);
            }
        });
    </script>
</body>

</html>